# Environment Configuration File
# Copy this to .env and fill in your values

# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-this-in-production
DJANGO_SETTINGS_MODULE=church_management.settings

# Database
DATABASE_URL=sqlite:///db.sqlite3
# For MySQL: DATABASE_URL=mysql://user:password@localhost:3306/church_db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/church_db

# Redis (for real-time updates and caching)
REDIS_URL=redis://localhost:6379/0
# For Heroku: REDIS_URL=redis://default:password@hostname:port

# Allowed Hosts
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com

# Time Zone
TIME_ZONE=UTC

# Security (set to True in production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
